# =============================================================================
# Hola Prime Admin Platform — Environment Variables
# Copy this file to .env and fill in your values.
# The API reads .env from its own folder OR from the parent (root) folder.
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://holaprime:holaprime_dev@localhost:5432/holaprime
POSTGRES_PASSWORD=holaprime_dev


# ── Auth (REQUIRED — change before going live) ────────────────────────────────
JWT_SECRET=dev_jwt_secret_change_in_prod_min_32_chars
JWT_REFRESH_SECRET=dev_refresh_secret_change_in_prod_min_32_chars
JWT_EXPIRY=15m

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ── GCP (optional for local dev — KYC document storage) ──────────────────────
GCP_PROJECT_ID=holaprime-prod
GCS_BUCKET=holaprime-kyc-docs
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── Email — SendGrid (needed for campaigns) ───────────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxx
EMAIL_FROM=noreply@holaprime.com

# ── WhatsApp — Meta Cloud API (needed for WA module) ─────────────────────────
WHATSAPP_PHONE_ID=your_phone_number_id
WHATSAPP_TOKEN=your_permanent_access_token
WHATSAPP_VERIFY_TOKEN=any_string_you_choose_for_webhook_verification

# ── Security ──────────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=200
RATE_LIMIT_WINDOW=60000

# ── Trading Platforms (all optional — only fill what you use) ─────────────────

# MT5
MT5_API_URL=https://your-mt5-bridge.com
MT5_API_KEY=your_mt5_api_key
MT5_SERVER=YourBroker-Server

# cTrader
CTRADER_CLIENT_ID=your_client_id
CTRADER_CLIENT_SECRET=your_client_secret
CTRADER_ACCOUNT_ID=your_account_id
CTRADER_ENV=demo

# MatchTrader
MATCHTRADER_API_URL=https://your-matchtrader-instance.com
MATCHTRADER_API_KEY=your_api_key

# NinjaTrader
NINJATRADER_API_URL=https://your-nt-bridge.com
NINJATRADER_API_KEY=your_api_key

# Tradovate
TRADOVATE_USERNAME=your_username
TRADOVATE_PASSWORD=your_password
TRADOVATE_APP_ID=your_app_id
TRADOVATE_APP_VERSION=1.0
TRADOVATE_CID=your_cid
TRADOVATE_SECRET=your_secret
TRADOVATE_ENV=demo

# ── Mailmodo (primary email provider) ────────────────────────────────────────
MAILMODO_API_KEY=your_mailmodo_api_key
# Campaign IDs — get these from Mailmodo > Transactional > [Campaign] > Trigger Info
MAILMODO_CAMPAIGN_WELCOME=
MAILMODO_CAMPAIGN_KYC_APPROVED=
MAILMODO_CAMPAIGN_KYC_REJECTED=
MAILMODO_CAMPAIGN_CHALLENGE_PURCHASED=
MAILMODO_CAMPAIGN_ACCOUNT_PASSED=
MAILMODO_CAMPAIGN_ACCOUNT_BREACHED=
MAILMODO_CAMPAIGN_PAYOUT_APPROVED=
MAILMODO_CAMPAIGN_PASSWORD_RESET=

# ── SumSub KYC ────────────────────────────────────────────────────────────────
SUMSUB_APP_TOKEN=your_sumsub_app_token
SUMSUB_SECRET_KEY=your_sumsub_secret_key
SUMSUB_LEVEL_NAME=basic-kyc-level
# Webhook URL to register in SumSub dashboard:
# https://your-api-domain.com/api/v1/sumsub/webhook

# ── Payment Gateways ─────────────────────────────────────────────────────────
# Note: gateway credentials are stored in the payment_gateways DB table.
# Use the admin panel (Settings > Payment Gateways) to configure them.
# These env vars are only needed if you skip the DB config:

# Stripe
STRIPE_SECRET_KEY=sk_live_xxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx

# PayPal
PAYPAL_CLIENT_ID=your_client_id
PAYPAL_CLIENT_SECRET=your_client_secret
PAYPAL_WEBHOOK_ID=your_webhook_id
PAYPAL_ENV=production

# NOWPayments (crypto)
NOWPAYMENTS_API_KEY=your_api_key
NOWPAYMENTS_IPN_SECRET=your_ipn_secret
NOWPAYMENTS_DEFAULT_COIN=USDTTRC20

# Flutterwave
FLUTTERWAVE_SECRET_KEY=FLWSECK_xxxx
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_xxxx
FLUTTERWAVE_ENCRYPTION_KEY=xxxx
FLUTTERWAVE_WEBHOOK_SECRET=your_webhook_hash

# Razorpay
RAZORPAY_KEY_ID=rzp_live_xxxx
RAZORPAY_KEY_SECRET=xxxx
RAZORPAY_WEBHOOK_SECRET=xxxx

# Skrill
SKRILL_MERCHANT_EMAIL=merchant@holaprime.com
SKRILL_SECRET_WORD=your_secret_word
SKRILL_MERCHANT_ID=your_merchant_id

# Neteller
NETELLER_CLIENT_ID=your_client_id
NETELLER_CLIENT_SECRET=your_client_secret

# App URLs (needed for payment redirects)
APP_URL=https://app.holaprime.com
API_BASE_URL=https://api.holaprime.com
