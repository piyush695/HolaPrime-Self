{
  "name": "holaprime-admin-backend",
  "version": "1.0.0",
  "description": "Hola Prime Admin Panel Backend",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "tsx src/db/migrate.ts",
    "migrate:rollback": "tsx src/db/migrate.ts rollback",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "seed": "tsx src/db/seed.ts",
    "setup": "npm run migrate && npm run seed"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/rate-limit": "^9.1.0",
    "@google-cloud/storage": "^7.7.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.4",
    "fastify": "^4.26.2",
    "fastify-plugin": "^4.5.1",
    "nanoid": "^3.3.7",
    "pg": "^8.11.3",
    "pino": "^8.19.0",
    "zod": "^3.22.4",
    "pino-pretty": "^10.3.1",
    "nodemailer": "^6.9.9",
    "pg-boss": "^10.1.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.11.5",
    "@types/pg": "^8.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.2",
    "@types/nodemailer": "^6.4.14"
  }
}
